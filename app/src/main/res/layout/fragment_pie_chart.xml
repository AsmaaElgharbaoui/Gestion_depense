<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <!-- Tabs période -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabPeriod"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_stats_bg"
        app:tabIndicatorColor="#2196F3"
        app:tabSelectedTextColor="#2196F3"
        app:tabTextColor="#666666"
        app:tabMode="fixed"
        app:tabGravity="fill">

        <com.google.android.material.tabs.TabItem
            android:text="Semaine"/>

        <com.google.android.material.tabs.TabItem
            android:text="Mois"/>

        <com.google.android.material.tabs.TabItem
            android:text="Année"/>
    </com.google.android.material.tabs.TabLayout>

    <!-- Navigation période -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/rounded_stats_bg"
        android:padding="8dp">

        <Button
            android:id="@+id/btnPrevious"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="40dp"
            android:text="◀"
            android:background="@drawable/button_blue_rounded"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/txtSelectedPeriod"
            android:layout_width="0dp"
            android:layout_weight="3"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="Février 2026"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#333333"/>

        <Button
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="40dp"
            android:text="▶"
            android:background="@drawable/button_blue_rounded"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- PieChart -->
    <com.github.mikephil.charting.charts.PieChart
        android:id="@+id/pieChart"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:layout_marginBottom="12dp"/>

    <!-- Message pas de données -->
    <TextView
        android:id="@+id/txtNoData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Aucune dépense pour cette période"
        android:textColor="#FF0000"
        android:gravity="center"
        android:visibility="gone"
        android:padding="12dp"/>

    <!-- Liste des catégories -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerStats"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"/>

</LinearLayout>